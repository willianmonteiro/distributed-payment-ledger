    {
      "id": "id4345768511",
      "type": "text",
      "x": 60,
      "y": 2020,
      "width": 943.8000000000001,
      "height": 60.0,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1161557138,
      "version": 1,
      "versionNonce": 556436892,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Resilience used throughout:\nFOR UPDATE SKIP LOCKED (outbox relay, no double-publish)  \u00b7  ON CONFLICT DO NOTHING (idempotency keys + incoming_transfers PK, safe redelivery)\nDLX/DLQ on both inbound queues  \u00b7  guarded status transitions (WHERE status = DEBITED)\nsuspense/transit account keeps each bank's own double-entry ledger balanced while money is \"in flight\".",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "Resilience used throughout:\nFOR UPDATE SKIP LOCKED (outbox relay, no double-publish)  \u00b7  ON CONFLICT DO NOTHING (idempotency keys + incoming_transfers PK, safe redelivery)\nDLX/DLQ on both inbound queues  \u00b7  guarded status transitions (WHERE status = DEBITED)\nsuspense/transit account keeps each bank's own double-entry ledger balanced while money is \"in flight\".",
      "lineHeight": 1.25
    }
