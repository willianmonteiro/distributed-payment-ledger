      "link": null,
      "locked": false,
      "text": "end-to-end flow: request -> local debit -> outbox -> broker -> remote credit -> reply -> settle (or compensate) -> reconciliation safety net",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "containerId": null,
      "originalText": "end-to-end flow: request -> local debit -> outbox -> broker -> remote credit -> reply -> settle (or compensate) -> reconciliation safety net",
      "lineHeight": 1.25
    },
