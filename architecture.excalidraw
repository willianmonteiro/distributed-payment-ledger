      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "10  InterbankReplyConsumer:\n\u2022 accepted ->\n    UPDATE interbank_transfers\n    SET status = CONFIRMED\n    WHERE status = DEBITED  (idempotent guard)\n\u2022 rejected ->\n    compensating transfer: suspense -> payer\n    idempotency_key = compensation-<transferId>\n    ON CONFLICT DO NOTHING\n    status = COMPENSATED",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "10  InterbankReplyConsumer:\n\u2022 accepted ->\n    UPDATE interbank_transfers\n    SET status = CONFIRMED\n    WHERE status = DEBITED  (idempotent guard)\n\u2022 rejected ->\n    compensating transfer: suspense -> payer\n    idempotency_key = compensation-<transferId>\n    ON CONFLICT DO NOTHING\n    status = COMPENSATED",
      "lineHeight": 1.25
    },
