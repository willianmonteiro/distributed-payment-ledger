    },
    {
      "id": "id4020012165",
      "type": "text",
      "x": 1332,
      "y": 1800,
      "width": 307.45000000000005,
      "height": 113.75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
