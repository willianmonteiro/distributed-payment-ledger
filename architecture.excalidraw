    {
      "id": "id6826616181",
      "type": "text",
      "x": 392,
      "y": 1800,
      "width": 300.3,
      "height": 130.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 395970335,
      "version": 1,
      "versionNonce": 1571754094,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Bank A  ledger_entries  (per transfer_id):\n  payer account        -amount\n  suspense account     +amount\n\nIf COMPENSATED (a new transfer -- never a\nrewrite of the original debit):\n  suspense account     -amount\n  payer account        +amount",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "containerId": null,
      "originalText": "Bank A  ledger_entries  (per transfer_id):\n  payer account        -amount\n  suspense account     +amount\n\nIf COMPENSATED (a new transfer -- never a\nrewrite of the original debit):\n  suspense account     -amount\n  payer account        +amount",
      "lineHeight": 1.25
    },
    {
