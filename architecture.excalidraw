      "updated": 1,
      "link": null,
      "locked": false,
      "text": "7  One Postgres transaction (InboundTransfersService):\n\u2022 INSERT incoming_transfers  (transfer_id PK)\n  ON CONFLICT DO NOTHING  -> dedupe on redelivery\n\u2022 payee found?\n    yes -> credit payee, debit Bank B's own\n           suspense account, status = CREDITED\n    no  -> status = REJECTED,\n           reject_reason = ACCOUNT_NOT_FOUND\n\u2022 COMMIT",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "7  One Postgres transaction (InboundTransfersService):\n\u2022 INSERT incoming_transfers  (transfer_id PK)\n  ON CONFLICT DO NOTHING  -> dedupe on redelivery\n\u2022 payee found?\n    yes -> credit payee, debit Bank B's own\n           suspense account, status = CREDITED\n    no  -> status = REJECTED,\n           reject_reason = ACCOUNT_NOT_FOUND\n\u2022 COMMIT",
      "lineHeight": 1.25
    },
