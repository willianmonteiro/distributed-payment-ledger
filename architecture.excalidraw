    {
      "id": "id1314395342",
      "type": "text",
      "x": 392,
      "y": 250,
      "width": 396.00000000000006,
      "height": 120.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1795823849,
      "version": 1,
      "versionNonce": 708506837,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "2  One Postgres transaction (InterbankTransfersService):\n\u2022 SELECT transfers WHERE idempotency_key = k  (replay check)\n\u2022 SELECT accounts WHERE id = payer FOR UPDATE  (row lock)\n\u2022 assert balance >= amount  (else 422 InsufficientFunds)\n\u2022 INSERT transfers  (payer -> suspense account)\n\u2022 INSERT interbank_transfers  (status = DEBITED)\n\u2022 INSERT outbox_events  (event = transfer.initiated)\n\u2022 COMMIT",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "2  One Postgres transaction (InterbankTransfersService):\n\u2022 SELECT transfers WHERE idempotency_key = k  (replay check)\n\u2022 SELECT accounts WHERE id = payer FOR UPDATE  (row lock)\n\u2022 assert balance >= amount  (else 422 InsufficientFunds)\n\u2022 INSERT transfers  (payer -> suspense account)\n\u2022 INSERT interbank_transfers  (status = DEBITED)\n\u2022 INSERT outbox_events  (event = transfer.initiated)\n\u2022 COMMIT",
      "lineHeight": 1.25
    },
