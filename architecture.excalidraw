      "text": "1  POST /interbank-transfers\n\nBody:\n{ payerAccountId,\n  payeeAccountRef,\n  amountCents }\n\nHeader:\nIdempotency-Key: k",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "1  POST /interbank-transfers\n\nBody:\n{ payerAccountId,\n  payeeAccountRef,\n  amountCents }\n\nHeader:\nIdempotency-Key: k",
