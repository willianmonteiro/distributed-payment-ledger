      "roundness": null,
      "seed": 1650747323,
      "version": 1,
      "versionNonce": 1423772582,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Bank B  ledger_entries  (only if CREDITED):\n  suspense account     -amount\n  payee account        +amount\n\nIf REJECTED: no ledger entries at Bank B --\nBank A's compensation is what makes the\npayer whole again.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "containerId": null,
      "originalText": "Bank B  ledger_entries  (only if CREDITED):\n  suspense account     -amount\n  payee account        +amount\n\nIf REJECTED: no ledger entries at Bank B --\nBank A's compensation is what makes the\npayer whole again.",
      "lineHeight": 1.25
    },
